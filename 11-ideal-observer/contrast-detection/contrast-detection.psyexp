    </Routine>
  </Routines>
  <Flow>
    <LoopInitiator loopType="TrialHandler" name="trials">
      <Param name="Selected rows" updates="None" val="" valType="str"/>
      <Param name="conditions" updates="None" val="[OrderedDict([('contrast_1', np.float64(0.0001)), ('contrast_2', np.float64(0.0))]), OrderedDict([('contrast_1', np.float64(0.001)), ('contrast_2', np.float64(0.0))]), OrderedDict([('contrast_1', np.float64(0.01)), ('contrast_2', np.float64(0.0))]), OrderedDict([('contrast_1', np.float64(0.03)), ('contrast_2', np.float64(0.0))]), OrderedDict([('contrast_1', np.float64(0.1)), ('contrast_2', np.float64(0.0))]), OrderedDict([('contrast_1', np.float64(0.3)), ('contrast_2', np.float64(0.0))]), OrderedDict([('contrast_1', np.float64(0.6)), ('contrast_2', np.float64(0.0))]), OrderedDict([('contrast_1', np.float64(0.0)), ('contrast_2', np.float64(0.0001))]), OrderedDict([('contrast_1', np.float64(0.0)), ('contrast_2', np.float64(0.001))]), OrderedDict([('contrast_1', np.float64(0.0)), ('contrast_2', np.float64(0.01))]), OrderedDict([('contrast_1', np.float64(0.0)), ('contrast_2', np.float64(0.03))]), OrderedDict([('contrast_1', np.float64(0.0)), ('contrast_2', np.float64(0.1))]), OrderedDict([('contrast_1', np.float64(0.0)), ('contrast_2', np.float64(0.3))]), OrderedDict([('contrast_1', np.float64(0.0)), ('contrast_2', np.float64(0.6))])]" valType="str"/>
      <Param name="conditionsFile" updates="None" val="contrast-detection-2ifc.csv" valType="file"/>
      <Param name="endPoints" updates="None" val="[0, 1]" valType="num"/>
      <Param name="isTrials" updates="None" val="True" valType="bool"/>
      <Param name="loopType" updates="None" val="random" valType="str"/>
      <Param name="nReps" updates="None" val="10" valType="num"/>
      <Param name="name" updates="None" val="trials" valType="code"/>
      <Param name="random seed" updates="None" val="" valType="code"/>
    </LoopInitiator>
    <Routine name="trial"/>
    <LoopTerminator name="trials"/>
  </Flow>
</PsychoPy2experiment>
